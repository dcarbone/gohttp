{
  "name": "dcarbone/gohttp",
  "type": "library",
  "license": "MIT",
  "description": "Golang-like http class(es) for PHP 8.2+",
  "homepage": "https://github.com/dcarbone/gohttp",
  "authors": [
    {
      "name": "The GOLANG Squad",
      "homepage": "https://golang.org/"
    },
    {
      "name": "Daniel Carbone",
      "email": "daniel.p.carbone@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "DCarbone\\Go\\HTTP\\": "src/"
    },
    "files": [
      "src/http_ns.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "DCarbone\\Go\\HTTP\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist"
  }
}